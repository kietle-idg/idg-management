{
  "rewrites": [
    { "source": "/api/ai-sync", "destination": "/api/ai-sync.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/crypto-prices", "destination": "/api/crypto-prices.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
